PORT=3000

# Copie este arquivo para .env (na pasta backend) e preencha. Sem .env o dotenv mostra "injecting env (0)".

# SQL Server
#
# Se no SSMS você usa "Autenticação do Windows" (como JONATHANMOREIRA\Jonathan), use:
#   DB_USE_WINDOWS_AUTH=true
#   DB_SERVER=JONATHANMOREIRA
#   (sem DB_USER / DB_PASSWORD)
# O Node usa o pacote msnodesqlv8; a conta Windows que roda "npm start" precisa ter acesso ao SQL.
#
# Autenticação SQL (usuário/senha, ex. sa) — deixe DB_USE_WINDOWS_AUTH=false ou remova:
# DB_USE_WINDOWS_AUTH=false
#
# Instância nomeada (ex.: SQLEXPRESS): DB_INSTANCE=SQLEXPRESS ou já coloque no DB_SERVER como MAQUINA\SQLEXPRESS.
# Porta TCP: SQL Server Configuration Manager → TCP/IP → IPAll; use DB_PORT sem instância nomeada.
DB_USE_WINDOWS_AUTH=true
DB_SERVER=JONATHANMOREIRA
DB_NAME=CacauParque
# Só para SQL auth (DB_USE_WINDOWS_AUTH=false):
# DB_USER=sa
# DB_PASSWORD=sua_senha

# DB_INSTANCE=SQLEXPRESS
# DB_PORT=1433

# ODBC (Windows): por omissão NÃO força ",1433" (SSMS muitas vezes usa pipes). Forçar TCP:
# DB_SQL_USE_TCP_PORT=true
# Ou defina o Server= completo, ex.: DB_ODBC_SERVER=(local) | localhost | MAQUINA,portaTCP
# DB_ODBC_SERVER=(local)

# Nome exacto do driver ODBC 64-bit (Administrador de origens de dados ODBC). Se só tiver o 18:
# DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# Google OAuth (console.cloud.google.com → APIs e serviços → Credenciais)
# Web client (tipo "Cliente OAuth da Web") — use para verificar o id_token no servidor
GOOGLE_CLIENT_ID=
# Android client (opcional, mesmo projeto) — inclua se o token vier do app Android
GOOGLE_ANDROID_CLIENT_ID=
# iOS client (opcional, mesmo projeto) — inclua se o token vier do app iOS
GOOGLE_IOS_CLIENT_ID=

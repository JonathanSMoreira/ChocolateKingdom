{
  "expo": {
    "scheme": "chocoapp",
    "name": "Choco Kingdom",
    "slug": "choco-app",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon-amusement-cs.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-native-composite.png",
      "resizeMode": "cover",
      "backgroundColor": "#1a1411"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "splash": {
        "image": "./assets/splash-native-composite.png",
        "resizeMode": "cover",
        "backgroundColor": "#1a1411"
      },
      "adaptiveIcon": {
        "backgroundColor": "#1a1411",
        "foregroundImage": "./assets/icon-amusement-cs.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.chocoapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "http://192.168.15.10:3000",
      "googleWebClientId": "",
      "googleAndroidClientId": "",
      "googleIosClientId": "",
      "eas": {
        "projectId": "c682ff26-b004-447f-98e8-59c03200ebfa"
      }
    },
    "plugins": [
      "expo-web-browser",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}

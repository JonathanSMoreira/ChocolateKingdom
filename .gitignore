# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# Office lock files (aberto no Word/Excel)
~$*

# Cópia alternativa quando DOCFUNCIONALIDADES_*.docx está aberto no Word
docs/*_novo.docx

# local env files
.env
.env*.local
backend/.env

# typescript
*.tsbuildinfo

# Snapshots locais / pastas de backup (duplicam código; não são o produto)
backup-pre-cleanup-*/

# SQL de rascunho / só para apagar manualmente
sql/*APAGAR*

# generated native folders
/ios
/android
